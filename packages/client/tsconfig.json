{
    "compilerOptions": {
        "skipLibCheck": true,
        "strict": false,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "module": "commonjs",
        "target": "esnext",
        "noImplicitAny": false,
        "outDir": "./dist",
        "esModuleInterop": true,
        "sourceMap": true,
        "inlineSources": true,
        "declaration": true,
        "strict": false,
        "resolveJsonModule": true,
    },
    "include": [
        "src/**/*"
    ],
}