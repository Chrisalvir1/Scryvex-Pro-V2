{
    "compilerOptions": {
        "module": "Node16",
        "target": "ES2021",
        "resolveJsonModule": true,
        "moduleResolution": "Node16",
        "esModuleInterop": true,
        "sourceMap": true,
        "strict": false,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "strictPropertyInitialization": false,
        "noImplicitThis": false,
        "skipLibCheck": true,
        "noImplicitOverride": false
    },
    "include": [
        "src/**/*"
    ]
}