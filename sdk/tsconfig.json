{
    "compilerOptions": {
        "skipLibCheck": true,
        "strict": false,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "module": "commonjs",
        "target": "ES2020",
        "noImplicitAny": false,
        "esModuleInterop": true,
        "sourceMap": true,
        "declaration": true,
        "outDir": "dist",
        "allowSyntheticDefaultImports": true,
        "strict": false,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "src/**/*",
    ],
}